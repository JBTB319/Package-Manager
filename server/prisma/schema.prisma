generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  packages  Package[]
  createdAt DateTime  @default(now())
}

model Recipient {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  site      String
  alias     String?
  location  String?
  type      String    @default("Internal")
  packages  Package[]
  createdAt DateTime  @default(now())
}

model Package {
  id          Int      @id @default(autoincrement())
  trackingNum String?
  description String?
  location    String
  dimensions  String?
  notes       String?

  recipient    Recipient? @relation(fields: [recipientId], references: [id])
  recipientId  Int?

  loggedInBy   User @relation(fields: [loggedInById], references: [id])
  loggedInById Int

  site    String
  courier String

  status     String   @default("RECEIVED")
  receivedAt DateTime @default(now())
  notifiedAt DateTime?
  pickedUpAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([recipientId])
  @@index([loggedInById])
}
