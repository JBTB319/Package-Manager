generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Site {
   SITE_1
   SITE_2
}

enum Status {
   RECIEVED
   NOTIFIED
   PICK_UP
   RETURN
   DISCARDED
}

model Recipient {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  site      Site
  packages  Package[]
}

model Package {
  id        Int      @id @default(autoincrement())
  
  name      String
  version   String
  createdAt DateTime @default(now())
}

model Receiptant {
   name     String
   email    String
   createdAt DateTime @default(now())
}
