generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum Site {
   SITE_1
   SITE_2
}

enum Courier {
  USPS
  UPS
  FEDEX
  DHL
  AMAZON
  OTHER
}

enum Status {
   RECEIVED
   NOTIFIED
   PICK_UP
   RETURN
   DISCARDED
}

model Recipient {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  site      Site      
  packages  Package[]
  createdAt DateTime  @default(now())
}

model Package {
  id          Int      @id @default(autoincrement())
  trackingNum String?
  description String?
  location    String   // ← add this
  dimensions  String?  // ← add this
  notes       String?  // ← add this

  recipient   Recipient? @relation(fields: [recipientId], references: [id])
  recipientId Int?

  loggedInBy  User     @relation(fields: [loggedInById], references: [id])
  loggedInById Int

  site        Site
  courier     Courier

  status      Status   @default(RECEIVED)  // ← fix enum name
  receivedAt  DateTime @default(now())
  notifiedAt  DateTime?
  pickedUpAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([recipientId])
  @@index([loggedInById])
}


